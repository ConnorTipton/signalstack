# ============================================================
# SignalStack V1 - environment configuration
# Copy to .env and fill in as you progress through the phases.
# Phase 1 needs only DATABASE_URL; everything else is added
# in later phases as providers come online.
# ============================================================

# --- Core ---------------------------------------------------
ENVIRONMENT=local
RUNTIME_MODE=build            # build | core | upgrade (blueprint section 7)
LOG_LEVEL=INFO
ALERTS_DRY_RUN=true           # true = log-only, no Telegram sends
MARKET_DATA_MAX_AGE_MINUTES=15 # stale quote/bar guard for selection and execution
MONITORED_TICKERS=AAPL,MSFT,NVDA,TSLA,AMZN,META,GOOGL,AMD,SPY,QQQ,IWM,NFLX,AVGO,PLTR
# Semicolon-separated source|url or source|url|ticker entries. Include ticker for issuer IR feeds.
RSS_FEEDS=businesswire|https://feeds.businesswire.com/rss/home/?rss=G22;globenewswire|https://www.globenewswire.com/RssFeed/subjectcode/15-Major+Periodic+Reports;prnewswire|https://prnewswire.com/rss/news-releases-list.rss

# --- Database (Phase 2) -------------------------------------
DATABASE_URL=postgresql+psycopg://signalstack:signalstack@localhost:5432/signalstack
# Optional test DB override. If unset, tests use DATABASE_URL database name + "_test".
TEST_DATABASE_URL=

# --- Market / options data (Phase 3) ------------------------
# Tradier (primary in Mode B). Leave blank in Mode A.
TRADIER_API_TOKEN=
TRADIER_ACCOUNT_ID=
TRADIER_ENVIRONMENT=sandbox   # sandbox | production

# Alpaca (Mode A fallback + Phase 8 paper execution)
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_PAPER=true             # must stay true in V1; live Alpaca trading is disabled

# --- News (Phase 4) ----------------------------------------
# Marketaux (Tier 2 aggregator). Phases 4a/4b only need RSS.
MARKETAUX_API_TOKEN=

# --- LLM (Phase 4d / 5) ------------------------------------
CLOUD_LLM_API_KEY=            # Anthropic API key for Claude Haiku labeling
CLAUDE_MODEL=claude-haiku-4-5-20251001

# --- Telegram (Phase 7) ------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
